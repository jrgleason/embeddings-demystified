# Embeddings Demo - Environment Configuration
# Copy this file to .env and update the values as needed
# DO NOT commit .env to version control

# Ollama Configuration
# =====================

# Base URL for the Ollama API server
# Default: http://10.0.0.9:11434
# For local development, you might want to use: http://localhost:11434
OLLAMA_BASE_URL=http://10.0.0.9:11434

# The Ollama model to use for chat/text generation
# Default: qwen3:0.6b
# Other options: llama2, mistral, codellama, etc.
# See: https://ollama.ai/library for available models
OLLAMA_MODEL=qwen3:0.6b

# The Ollama model to use for generating embeddings
# Default: qwen3-embedding:0.6b
# Other options: nomic-embed-text, mxbai-embed-large, etc.
# See: https://ollama.ai/library for available embedding models
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
