import express from "express";
import ViteExpress from "vite-express";
import { ChatOllama } from "@langchain/ollama";
import { HumanMessage, SystemMessage } from "@langchain/core/messages";

const app = express();

// Parse JSON request bodies
app.use(express.json());

app.get("/message", (_, res) => res.send("Hello from express!"));

// Simple health check for AI route
app.get("/ai/health", async (_, res) => {
  try {
    const model = new ChatOllama({
      baseUrl: process.env.OLLAMA_BASE_URL || "http://10.0.0.9:11434",
      model: process.env.OLLAMA_MODEL || "qwen3:0.6b",
      temperature: 0,
    });
    const ctrl = new AbortController();
    const timer = setTimeout(() => ctrl.abort(), 2500);
    await model.invoke([new HumanMessage("ping")], { signal: ctrl.signal });
    clearTimeout(timer);
    res.json({ ok: true });
  } catch (err) {
    res.status(503).json({ ok: false, error: `${err}` });
  }
});

// POST /ai { prompt: string, system?: string, stream?: boolean }
app.post("/ai", async (req, res) => {
  const { prompt, system, stream } = req.body || {};
  if (!prompt || typeof prompt !== "string") {
    return res.status(400).json({ error: "Missing required 'prompt' string in request body." });
  }

  const baseUrl = process.env.OLLAMA_BASE_URL || "http://10.0.0.9:11434";
  const modelName = process.env.OLLAMA_MODEL || "qwen3:0.6b";

  const llm = new ChatOllama({
    baseUrl,
    model: modelName,
    temperature: 0.2,
  });

  const messages = [
    system ? new SystemMessage(system) : null,
    new HumanMessage(prompt),
  ].filter(Boolean);

  const wantsStream = stream === true || (req.headers.accept || "").includes("text/event-stream");

  if (wantsStream) {
    // Setup Server-Sent Events (SSE)
    res.setHeader("Content-Type", "text/event-stream");
    res.setHeader("Cache-Control", "no-cache");
    res.setHeader("Connection", "keep-alive");
    // Allow CORS for dev convenience (optional)
    res.setHeader("Access-Control-Allow-Origin", "*");

    // Heartbeat to keep connection open (optional)
    const heartbeat = setInterval(() => {
      res.write("event: ping\ndata: \n\n");
    }, 15000);

    let full = "";
    let closed = false;
    req.on("close", () => {
      closed = true;
      clearInterval(heartbeat);
    });

    try {
      for await (const chunk of llm.stream(messages)) {
        if (closed) break;
        // chunk could be a message chunk; normalize content piece
        const piece = Array.isArray(chunk.content)
          ? chunk.content.map((c) => (typeof c === "string" ? c : c.text ?? "")).join("")
          : chunk.content || "";
        if (piece) {
          full += piece;
          res.write(`event: token\ndata: ${JSON.stringify(piece)}\n\n`);
        }
      }
      if (!closed) {
        res.write(`event: done\ndata: ${JSON.stringify({ model: modelName, output: full })}\n\n`);
      }
    } catch (error) {
      if (!closed) {
        res.write(`event: error\ndata: ${JSON.stringify({ message: "Streaming failed", details: String(error) })}\n\n`);
      }
    } finally {
      clearInterval(heartbeat);
      if (!closed) res.end();
    }
    return; // Prevent non-streaming path
  }

  // Non-streaming path
  try {
    const result = await llm.invoke(messages);
    const content = Array.isArray(result.content)
      ? result.content.map((c) => (typeof c === "string" ? c : c.text ?? "")).join("")
      : result.content;

    res.json({
      model: modelName,
      baseUrl,
      output: content,
      raw: {
        id: result.id,
        role: result._getType?.() ?? result.role,
      },
    });
  } catch (error) {
    res.status(502).json({
      error: "Failed to get response from Ollama",
      details: `${error}`,
      model: modelName,
      baseUrl,
      hint: "Ensure the Ollama server is reachable and the model is pulled on the target host.",
    });
  }
});

ViteExpress.listen(app, 3000, () => console.log("Server is listening..."));